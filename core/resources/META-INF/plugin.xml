<idea-plugin>
    <id>com.termlab.core</id>
    <name>TermLab Core</name>
    <version>0.1.0</version>
    <vendor>TermLab</vendor>
    <description>Terminal-driven workstation built on IntelliJ Platform</description>

    <depends>com.intellij.modules.platform</depends>

    <!-- TermLab-defined extension points for plugins to implement -->
    <extensionPoints>
        <extensionPoint name="terminalSessionProvider"
                        interface="com.termlab.sdk.TerminalSessionProvider"
                        dynamic="true"/>
        <extensionPoint name="credentialProvider"
                        interface="com.termlab.sdk.CredentialProvider"
                        dynamic="true"/>
        <extensionPoint name="fileSourceProvider"
                        interface="com.termlab.core.filepicker.FileSourceProvider"
                        dynamic="true"/>
    </extensionPoints>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService
            serviceInterface="com.intellij.openapi.fileEditor.impl.EditorEmptyTextPainter"
            serviceImplementation="com.termlab.core.TermLabEmptyTextPainter"
            overrides="true"/>

        <applicationConfigurable
            parentId="root"
            instance="com.termlab.core.settings.TermLabTerminalConfigurable"
            id="termlab.terminal.settings"
            displayName="TermLab Terminal"/>

        <applicationConfigurable
            parentId="termlab.terminal.settings"
            instance="com.termlab.core.settings.TermLabTerminalAppearanceConfigurable"
            id="termlab.terminal.settings.appearance"
            displayName="Appearance"/>

        <applicationConfigurable
            parentId="termlab.terminal.settings"
            instance="com.termlab.core.settings.TermLabTerminalTerminalConfigurable"
            id="termlab.terminal.settings.terminal"
            displayName="Terminal"/>

        <search.optionContributor
            implementation="com.termlab.core.settings.TermLabSearchableOptionContributor"/>

        <!--
          Skip the platform welcome frame entirely and open ~ as the
          default workspace on every cold launch. TermLab has no concept
          of picking a "project" — the user's home directory is the
          base the terminal launches shells from. See
          TermLabHomeDirNoProjectHandler for the hook point (IdeStarter
          calls this before showWelcomeFrame).
        -->
        <noProjectStateHandler
            implementation="com.termlab.core.TermLabHomeDirNoProjectHandler"/>

        <!--
          TermLab Dark UI theme. Referenced as the product default LaF
          in TermLabApplicationInfo.xml via
          <default-laf light-classic="TermLab Light"
                       dark-classic="TermLab Dark"/>.
        -->
        <themeProvider id="termlab.dark"
                       path="/themes/TermLabDark.theme.json"
                       targetUi="classic"/>

        <!--
          TermLab Light UI theme. Complementary light variant of
          TermLab Dark, loaded from the curated termlab-light JSON.
        -->
        <themeProvider id="termlab.light"
                       path="/themes/TermLabLight.theme.json"
                       targetUi="classic"/>

        <!--
          TermLab Dark editor + terminal color scheme. Inherits
          Darcula and overrides the 16-color ANSI palette plus editor
          background/selection/caret colors. TermLabTerminalSettings
          reads these ANSI keys at runtime to drive the terminal
          palette; the .theme.json above references this scheme via
          its `editorScheme` field.
        -->
        <bundledColorScheme id="TermLab Dark"
                            path="/colorSchemes/TermLabDark"/>

        <bundledColorScheme id="TermLab Light"
                            path="/themes/termlab-flow-day"/>

        <fileEditorProvider
            implementation="com.termlab.core.terminal.TermLabTerminalEditorProvider"/>

        <editorTabTitleProvider
            implementation="com.termlab.core.terminal.TermLabEditorTabTitleProvider"
            order="first"/>

        <postStartupActivity
            implementation="com.termlab.core.TermLabStartupActivity"/>

        <projectFrameCapabilitiesProvider
            implementation="com.termlab.core.TermLabProjectFrameCapabilitiesProvider"/>

        <actionConfigurationCustomizer
            implementation="com.termlab.core.actions.TermLabActionConfigurationCustomizer"/>

        <defaultToolWindowLayout
            implementation="com.termlab.core.TermLabDefaultToolWindowLayout"
            order="last"/>

        <projectService
            serviceImplementation="com.termlab.core.workspace.WorkspaceManager"/>

        <!-- TermLab intentionally suppresses plugin-advertiser prompts.
             This prevents marketplace-style notifications such as
             "Plugin ... supporting run configuration ... is not installed". -->
        <projectService
            overrides="true"
            serviceInterface="com.intellij.openapi.updateSettings.impl.pluginsAdvertisement.PluginAdvertiserService"
            serviceImplementation="com.intellij.openapi.updateSettings.impl.pluginsAdvertisement.HeadlessPluginAdvertiserServiceImpl"/>

        <searchEverywhereContributor
            implementation="com.termlab.core.palette.TerminalPaletteContributor$Factory"/>

        <!-- Override the platform's TabsCustomizationStrategy to only show
             Actions and Terminals tabs in Search Everywhere -->
        <applicationService
            serviceInterface="com.intellij.ide.actions.searcheverywhere.TabsCustomizationStrategy"
            serviceImplementation="com.termlab.core.palette.TermLabTabsCustomizationStrategy"
            overrides="true"/>
    </extensions>

    <applicationListeners>
        <listener class="com.termlab.core.TermLabProjectCloseListener"
                  topic="com.intellij.openapi.project.ProjectManagerListener"/>
        <!--
          Strips built-in Search Everywhere contributors (files, classes,
          symbols, text, run configs, top hits, calculator, YAML keys) so the
          Command Palette's "All" tab only shows TermLab things. Fires on
          appFrameCreated, before the user can open Search Everywhere.
        -->
        <listener class="com.termlab.core.palette.TermLabSearchEverywhereCustomizer"
                  topic="com.intellij.ide.AppLifecycleListener"/>

        <!--
          Strips IDE-oriented tool windows (Problems View, etc.) that bundled
          modules still register via <toolWindow> extensions. Same
          appFrameCreated hook so the stripe buttons never get painted.
        -->
        <listener class="com.termlab.core.TermLabToolWindowCustomizer"
                  topic="com.intellij.ide.AppLifecycleListener"/>

        <!--
          Unregisters the platform's refactoring actions and group so the
          Ctrl+T "Refactor This" popup and top-level Refactor menu vanish.
          See TermLabRefactoringStripper for the list and the rationale.
        -->
        <listener class="com.termlab.core.TermLabRefactoringStripper"
                  topic="com.intellij.ide.AppLifecycleListener"/>

        <!--
          Unregisters main-toolbar actions that don't apply to a
          terminal workstation: Save All, Synchronize, Back/Forward,
          Add Configuration, Run, Stop, plus the top-level Run and
          Build menus. Mirrors TermLabRefactoringStripper's approach —
          action-level removal kills the toolbar slot, the menu
          entry, the Search Everywhere hit, and any keybinding in
          one step. Run / Stop specifically get replaced with
          NoopExecutorStubAction to defend against platform code
          paths that unconditionally look them up by id.
        -->
        <listener class="com.termlab.core.TermLabToolbarStripper"
                  topic="com.intellij.ide.AppLifecycleListener"/>

        <!--
          Strips IDE-oriented Settings pages under Editor/ that don't affect
          the terminal view. Keeps Font, Color Scheme, and General/Appearance.
          Project-scoped pages are stripped from TermLabStartupActivity per
          project open. See TermLabEditorSettingsStripper for details.
        -->
        <listener class="com.termlab.core.TermLabEditorSettingsStripper"
                  topic="com.intellij.ide.AppLifecycleListener"/>

        <!--
          Overrides the macOS Dock icon with a full-res 1024x1024 PNG.
          IntelliJ's AppUIUtil.updateAppWindowIcon loads the app SVG at
          size=32 and calls Taskbar.setIconImage with that, so the dock
          icon otherwise appears blurry in dev mode. See
          TermLabMacDockIconCustomizer for the detailed rationale.
        -->
        <listener class="com.termlab.core.TermLabMacDockIconCustomizer"
                  topic="com.intellij.ide.AppLifecycleListener"/>

        <!--
          Removes built-in Darcula / IntelliJ Light theme providers so only
          TermLab themes appear in the theme picker.
        -->
        <listener class="com.termlab.core.TermLabBuiltInThemeStripper"
                  topic="com.intellij.ide.AppLifecycleListener"/>

        <!--
          Points OS theme sync to TermLab Light / TermLab Dark instead of
          IntelliJ defaults, and keeps first-launch fallback on TermLab Light.
        -->
        <listener class="com.termlab.core.TermLabThemeSyncCustomizer"
                  topic="com.intellij.ide.AppLifecycleListener"/>

        <!--
          Disables the platform's external file watcher integration
          for TermLab. The native watcher is what triggers the
          "External file changes sync might be slow" balloon when it
          is missing or fails to start, but TermLab does not depend
          on external file sync or indexing. We already bake
          -Didea.filewatcher.disabled=true into launcher vmoptions;
          this listener mirrors that at runtime for launch paths
          that bypass those vmoptions, then eagerly initializes the
          LocalFileSystem with the disabled flag in place.
        -->
        <listener class="com.termlab.core.TermLabFileWatcherDisabler"
                  topic="com.intellij.ide.AppLifecycleListener"/>

        <!--
          Flips the ide.check.windows.defender.rules registry key
          off at startup so the Windows Defender exclusion-check
          post-startup activity bails out via
          ExtensionNotApplicableException and never pops its "add
          your project to Defender exclusions" notification. TermLab
          doesn't index files so the check has nothing to offer.
          No-op on non-Windows hosts. See
          TermLabDefenderNotifierSuppressor for the registry key
          lookup chain.
        -->
        <listener class="com.termlab.core.TermLabDefenderNotifierSuppressor"
                  topic="com.intellij.ide.AppLifecycleListener"/>

        <!--
          Pins Search Everywhere to the upper-half-center of the TermLab
          frame on every invocation, instead of the platform's default
          of remembering the user's drag position across opens. See
          TermLabSearchEverywhereLocationPinner.

          Known caveat: with this listener active, the first Cmd+Shift+P
          press after moving the TermLab window currently requires a
          second press to render the popup. Verified unrelated to this
          listener (bug reproduces with it removed entirely); documented
          here as a trade-off we're accepting for now.
        -->
        <listener class="com.termlab.core.palette.TermLabSearchEverywhereLocationPinner"
                  topic="com.intellij.openapi.actionSystem.ex.AnActionListener"/>
        <listener class="com.termlab.core.terminal.TermLabDistractionFreeModeListener"
                  topic="com.intellij.openapi.actionSystem.ex.AnActionListener"/>
    </applicationListeners>

    <projectListeners>
        <listener class="com.termlab.core.terminal.TermLabTerminalOnlyFileEditorListener"
                  topic="com.intellij.openapi.fileEditor.FileEditorManagerListener"/>

        <!--
          Reactive stripper for dynamically-registered tool windows
          (Run, Debug, Hierarchy, Services). These don't use the static
          <toolWindow> extension point — they're registered by service
          constructors at project-open time. TermLabToolWindowStripper
          catches them as they register via toolWindowRegistered() and
          immediately unregisters them. Also sweeps any that registered
          before the listener wired up.
        -->
        <listener class="com.termlab.core.TermLabToolWindowStripper"
                  topic="com.intellij.openapi.wm.ex.ToolWindowManagerListener"/>
    </projectListeners>

    <actions>
        <action id="TermLab.ToggleDistractionFreeModeShortcut"
                class="com.termlab.core.actions.ToggleDistractionFreeModeShortcutAction"
                text="Toggle Distraction Free Mode"
                description="Toggle distraction free mode">
            <keyboard-shortcut keymap="$default" first-keystroke="control shift Z"/>
            <keyboard-shortcut keymap="Mac OS X 10.5+" first-keystroke="meta shift Z" replace-all="true"/>
            <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta shift Z" replace-all="true"/>
        </action>

        <!--
          Stub registered as id="Debug" so platform code that unconditionally
          looks up this action (notably RunToolbarTopLevelExecutorActionGroup
          in RedesignedRunWidget.kt) doesn't NPE on startup. TermLab strips the
          xdebugger modules via essential.minimal, so the real Debug executor
          never registers its action. See NoopExecutorStubAction docs for the
          full story.
        -->
        <action id="Debug"
                class="com.termlab.core.actions.NoopExecutorStubAction"
                text=""
                description="No-op stub — TermLab has no debugger"/>

        <action id="TermLab.CommandPalette"
                class="com.intellij.ide.actions.SearchEverywhereAction"
                text="Command Palette"
                description="Open the TermLab command palette">
            <!-- $default = Linux/Windows: Ctrl+Shift+P (VS Code convention).
                 Mac overrides use Cmd+Shift+P via `meta`. -->
            <keyboard-shortcut keymap="$default" first-keystroke="control shift P"/>
            <keyboard-shortcut keymap="Mac OS X 10.5+" first-keystroke="meta shift P" replace-all="true"/>
            <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta shift P" replace-all="true"/>
        </action>

        <!--
          Rename the currently-focused terminal tab. Added to
          EditorTabPopupMenu programmatically by
          TermLabActionConfigurationCustomizer so it's the single entry in the
          tab right-click menu (the rest of the inherited file-oriented
          entries get cleared). Bound to F2 globally so the shortcut works
          whether or not the popup is open.
        -->
        <action id="TermLab.RenameTerminalTab"
                class="com.termlab.core.actions.RenameTerminalTabAction"
                text="Rename Tab…"
                description="Rename the current terminal tab">
            <keyboard-shortcut keymap="$default" first-keystroke="F2"/>
        </action>

        <group id="TermLab.TerminalActions" text="Terminal" popup="true">
            <add-to-group group-id="MainMenu" anchor="before" relative-to-action="HelpMenu"/>

            <!-- $default (Linux/Windows) uses ctrl+shift+<key> to avoid
                 colliding with terminal key bindings (ctrl+T / ctrl+W /
                 ctrl+D are common emacs/readline bindings). Mac keeps
                 plain meta+<key> per native convention. -->
            <action id="TermLab.NewTerminalTab"
                    class="com.termlab.core.actions.NewTerminalTabAction"
                    text="New Terminal Tab"
                    description="Open a new local terminal tab">
                <keyboard-shortcut keymap="$default" first-keystroke="control shift T"/>
                <keyboard-shortcut keymap="Mac OS X 10.5+" first-keystroke="meta T" replace-all="true"/>
                <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta T" replace-all="true"/>
            </action>

            <action id="TermLab.CloseTerminalTab"
                    class="com.termlab.core.actions.CloseTerminalTabAction"
                    text="Close Terminal Tab"
                    description="Close the active terminal tab">
                <keyboard-shortcut keymap="$default" first-keystroke="control shift W"/>
                <keyboard-shortcut keymap="Mac OS X 10.5+" first-keystroke="meta W" replace-all="true"/>
                <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta W" replace-all="true"/>
            </action>

            <action id="TermLab.SplitHorizontal"
                    class="com.termlab.core.actions.SplitTerminalHorizontalAction"
                    text="Split Terminal Right"
                    description="Split and open a new terminal to the right">
                <keyboard-shortcut keymap="$default" first-keystroke="control shift E"/>
                <keyboard-shortcut keymap="Mac OS X 10.5+" first-keystroke="meta D" replace-all="true"/>
                <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta D" replace-all="true"/>
            </action>

            <action id="TermLab.SplitVertical"
                    class="com.termlab.core.actions.SplitTerminalVerticalAction"
                    text="Split Terminal Down"
                    description="Split and open a new terminal below">
                <keyboard-shortcut keymap="$default" first-keystroke="control shift O"/>
                <keyboard-shortcut keymap="Mac OS X 10.5+" first-keystroke="meta shift D" replace-all="true"/>
                <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta shift D" replace-all="true"/>
            </action>

            <separator/>

            <action id="TermLab.FocusTerminalLeft"
                    class="com.termlab.core.actions.FocusTerminalLeftAction"
                    text="Focus Terminal Left"
                    description="Move focus to the terminal split on the left">
                <keyboard-shortcut keymap="$default" first-keystroke="alt shift LEFT"/>
                <keyboard-shortcut keymap="Mac OS X 10.5+" first-keystroke="meta alt LEFT" replace-all="true"/>
                <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta alt LEFT" replace-all="true"/>
            </action>

            <action id="TermLab.FocusTerminalRight"
                    class="com.termlab.core.actions.FocusTerminalRightAction"
                    text="Focus Terminal Right"
                    description="Move focus to the terminal split on the right">
                <keyboard-shortcut keymap="$default" first-keystroke="alt shift RIGHT"/>
                <keyboard-shortcut keymap="Mac OS X 10.5+" first-keystroke="meta alt RIGHT" replace-all="true"/>
                <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta alt RIGHT" replace-all="true"/>
            </action>

            <action id="TermLab.FocusTerminalUp"
                    class="com.termlab.core.actions.FocusTerminalUpAction"
                    text="Focus Terminal Up"
                    description="Move focus to the terminal split above">
                <keyboard-shortcut keymap="$default" first-keystroke="alt shift UP"/>
                <keyboard-shortcut keymap="Mac OS X 10.5+" first-keystroke="meta alt UP" replace-all="true"/>
                <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta alt UP" replace-all="true"/>
            </action>

            <action id="TermLab.FocusTerminalDown"
                    class="com.termlab.core.actions.FocusTerminalDownAction"
                    text="Focus Terminal Down"
                    description="Move focus to the terminal split below">
                <keyboard-shortcut keymap="$default" first-keystroke="alt shift DOWN"/>
                <keyboard-shortcut keymap="Mac OS X 10.5+" first-keystroke="meta alt DOWN" replace-all="true"/>
                <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta alt DOWN" replace-all="true"/>
            </action>

            <separator/>

            <action id="TermLab.SaveWorkspace"
                    class="com.termlab.core.actions.SaveWorkspaceAction"
                    text="Save Workspace As..."
                    description="Save the current workspace layout">
                <keyboard-shortcut keymap="$default" first-keystroke="control alt S"/>
                <keyboard-shortcut keymap="Mac OS X 10.5+" first-keystroke="meta shift S" replace-all="true"/>
                <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta shift S" replace-all="true"/>
            </action>

            <action id="TermLab.LoadWorkspace"
                    class="com.termlab.core.actions.LoadWorkspaceAction"
                    text="Load Workspace"
                    description="Load a saved workspace">
            </action>
        </group>
    </actions>

    <extensions defaultExtensionNs="com.termlab.core">
        <fileSourceProvider implementation="com.termlab.core.filepicker.LocalFileSourceProvider"/>
    </extensions>
</idea-plugin>
