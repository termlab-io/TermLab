<component xmlns="http://jetbrains.org/intellij/schema/application-info">
  <version major="2026" minor="2" eap="true" codename="Workstation"/>
  <company name="Conch" url="https://github.com/conch"/>
  <build number="CN-__BUILD__" date="__BUILD_DATE__"/>
  <logo url="/conch_logo.png"/>
  <icon svg="/conch-icon.svg" svg-small="/conch-icon_16.svg"/>
  <names product="Conch" fullname="Conch Workbench" script="conch"
         motto="Terminal-Driven Workstation"/>
  <!--
    Product default LaF. LafManagerImpl reads `dark-classic` via
    ApplicationInfoEx.defaultClassicDarkLaf because Conch ships with
    classic UI (New UI is disabled via -Dide.experimental.ui=false).
    The value is looked up first by theme id, then by display name —
    "Conch Dark" matches the `name` field in Conch.theme.json.
  -->
  <default-laf dark-classic="Conch Dark"/>
  <essential-plugin>com.conch.core</essential-plugin>
  <essential-plugin>com.conch.ssh</essential-plugin>
  <essential-plugin>com.conch.vault</essential-plugin>
  <essential-plugin>com.conch.tunnels</essential-plugin>
  <essential-plugin>com.intellij.classic.ui</essential-plugin>
  <essential-plugin>com.intellij.modules.json</essential-plugin>
</component>
