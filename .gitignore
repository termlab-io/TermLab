# Local config written by setup.sh — absolute path to intellij-community
/.intellij-root
/.worktrees/

# Bazel build outputs (live in the intellij tree, not here, but just in case)
/bazel-*
/out/

# IntelliJ project state. Conch lives inside the intellij-community project;
# this repo is never opened as its own IntelliJ project, so any .idea/ that
# appears here is stale junk from accidental opens.
.idea/

# Auto-generated short-named .iml files from IntelliJ when it indexes the
# conch modules from the symlinked path. The canonical .iml files we ship
# are named intellij.conch.{main,core,sdk,customization}.iml; anything else
# is regenerated noise.
core/core.iml
sdk/sdk.iml
customization/customization.iml

# OS junk
.DS_Store
Thumbs.db

# Editor scratch
*.swp
*~

# Local perf harness artifacts
perf-results/
/.perf-workspace/

# Scratch log files shared back from Windows/Linux VMs for debugging
/idea.log
/exceptions
