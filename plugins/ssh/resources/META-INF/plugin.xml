<idea-plugin>
    <id>com.conch.ssh</id>
    <name>Conch SSH</name>
    <vendor>Conch</vendor>
    <description>SSH host manager and session provider. Opens remote
    shells as terminal tabs using credentials from the Conch Vault.</description>

    <!--
      com.conch.core declares the terminalSessionProvider extension point.
      com.conch.vault provides the credentialProvider we consume when
      resolving saved host credentials — ordering the dependency also
      guarantees the vault's extension is registered before our
      SshSessionProvider tries to look it up.
    -->
    <depends>com.conch.core</depends>
    <depends>com.conch.vault</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!--
          HostStore is the single source of truth for "what SSH hosts does
          the user have saved". Registered as an application service so the
          tool window, palette contributor, and session provider all share
          one instance; the service constructor loads from disk on first
          access.
        -->
        <applicationService serviceImplementation="com.conch.ssh.model.HostStore"/>

        <!--
          ConchSshClient owns a single MINA SshClient instance and its
          internal IO thread pool. Registering as an application service so
          the pool persists across sessions instead of being re-created per
          connection.
        -->
        <applicationService serviceImplementation="com.conch.ssh.client.ConchSshClient"/>
    </extensions>

    <!--
      Register the SSH session provider under the core extension point.
      Phase 5 adds actions (New SSH Session on Cmd+K / Ctrl+K), a Hosts
      tool window, and a host-picker dialog — until those land, the
      provider is reachable programmatically but not yet from any menu.
    -->
    <extensions defaultExtensionNs="com.conch.core">
        <terminalSessionProvider implementation="com.conch.ssh.provider.SshSessionProvider"/>
    </extensions>
</idea-plugin>
