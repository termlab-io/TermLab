<idea-plugin>
    <id>com.termlab.ssh</id>
    <name>TermLab SSH</name>
    <vendor>TermLab</vendor>
    <description>SSH host manager and session provider. Opens remote
    shells as terminal tabs using credentials from the TermLab Vault.</description>

    <!--
      com.termlab.core declares the terminalSessionProvider extension point.
      com.termlab.vault provides the credentialProvider we consume when
      resolving saved host credentials — ordering the dependency also
      guarantees the vault's extension is registered before our
      SshSessionProvider tries to look it up.
    -->
    <depends>com.termlab.core</depends>
    <depends>com.termlab.vault</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!--
          HostStore is the single source of truth for "what SSH hosts does
          the user have saved". Registered as an application service so the
          tool window, palette contributor, and session provider all share
          one instance; the service constructor loads from disk on first
          access.
        -->
        <applicationService serviceImplementation="com.termlab.ssh.model.HostStore"/>

        <!--
          TermLabSshClient owns a single MINA SshClient instance and its
          internal IO thread pool. Registering as an application service so
          the pool persists across sessions instead of being re-created per
          connection.
        -->
        <applicationService serviceImplementation="com.termlab.ssh.client.TermLabSshClient"/>

        <!--
          Hosts tool window — left sidebar, between Project and Structure
          in practice. Icon uses AllIcons.Webreferences.Server to match
          the SSH provider icon in the terminal editor.
        -->
        <toolWindow id="Hosts"
                    anchor="right"
                    icon="AllIcons.Webreferences.Server"
                    factoryClass="com.termlab.ssh.toolwindow.HostsToolWindowFactory"/>
        <searchEverywhereContributor
            implementation="com.termlab.ssh.palette.HostsSearchEverywhereContributor$Factory"/>
    </extensions>

    <!--
      Register the SSH session provider and the palette contributor under
      the core extension points.
    -->
    <extensions defaultExtensionNs="com.termlab.core">
        <terminalSessionProvider implementation="com.termlab.ssh.provider.SshSessionProvider"/>
    </extensions>

    <actions>
        <!--
          "New SSH Session…" — Cmd+K on macOS, Ctrl+K on Linux/Windows.
          Opens a host picker from anywhere in the IDE. Same code path as
          the palette's Hosts tab, just a different entry point.
        -->
        <action id="TermLab.NewSshSession"
                class="com.termlab.ssh.actions.NewSshSessionAction"
                text="New SSH Session…"
                description="Open the host picker and start a new SSH session">
            <keyboard-shortcut keymap="$default" first-keystroke="meta K"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl K"/>
        </action>
    </actions>
</idea-plugin>
