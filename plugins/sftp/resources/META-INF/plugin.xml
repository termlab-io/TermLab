<idea-plugin>
    <id>com.termlab.sftp</id>
    <name>SFTP</name>
    <version>0.1.0</version>
    <vendor>TermLab</vendor>
    <description>
        Dual-pane SFTP browser for TermLab. Browse local files
        alongside a remote SSH host's filesystem, reusing TermLab's existing
        SSH host credentials (vault / keyfile / prompt), proxy-jump, and
        host-key verifier.
    </description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.termlab.core</depends>
    <depends>com.termlab.ssh</depends>

    <extensionPoints>
        <extensionPoint name="localFileOpener"
                        interface="com.termlab.sftp.spi.LocalFileOpener"
                        dynamic="true"/>
        <extensionPoint name="remoteFileOpener"
                        interface="com.termlab.sftp.spi.RemoteFileOpener"
                        dynamic="true"/>
    </extensionPoints>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup
            id="SFTP"
            displayType="BALLOON"
            toolWindowId="SFTP"/>

        <applicationService
            serviceImplementation="com.termlab.sftp.persistence.TermLabSftpConfig"/>

        <applicationService
            serviceImplementation="com.termlab.sftp.session.SftpSessionManager"/>

        <toolWindow
            id="SFTP"
            anchor="bottom"
            icon="AllIcons.Nodes.ExtractedFolder"
            factoryClass="com.termlab.sftp.toolwindow.SftpToolWindowFactory"/>

        <searchEverywhereContributor
            implementation="com.termlab.sftp.palette.SftpSearchEverywhereContributor$Factory"/>

        <virtualFileSystem
            implementationClass="com.termlab.sftp.vfs.SftpVirtualFileSystem"
            key="sftp"
            physical="false"/>
    </extensions>

    <extensions defaultExtensionNs="com.termlab.core">
        <fileSourceProvider implementation="com.termlab.sftp.filepicker.SftpFileSourceProvider"/>
    </extensions>

    <projectListeners>
        <listener class="com.termlab.sftp.session.SftpEditorTabListener"
                  topic="com.intellij.openapi.fileEditor.FileEditorManagerListener"/>
    </projectListeners>

    <actions>
        <group id="TermLab.Sftp.ViewMenu"
               text="SFTP"
               description="SFTP tool window view options"
               popup="true">
            <add-to-group group-id="ViewMenu" anchor="last"/>

            <action id="TermLab.Sftp.View.Local"
                    class="com.termlab.sftp.actions.ShowLocalSftpPaneAction"
                    text="Local"/>
            <action id="TermLab.Sftp.View.Remote"
                    class="com.termlab.sftp.actions.ShowRemoteSftpPaneAction"
                    text="Remote"/>
            <action id="TermLab.Sftp.View.Both"
                    class="com.termlab.sftp.actions.ShowLocalAndRemoteSftpPanesAction"
                    text="Local + Remote"/>
        </group>

        <!--
          "New SFTP Session…" — Cmd+Shift+K on macOS, Ctrl+Shift+K on
          Linux/Windows. Mirrors the SSH plugin's Cmd+K popup: pick a
          saved host, open the SFTP tool window, connect on select.
        -->
        <action id="TermLab.NewSftpSession"
                class="com.termlab.sftp.actions.NewSftpSessionAction"
                text="New SFTP Session…"
                description="Open the host picker and start a new SFTP session">
            <keyboard-shortcut keymap="$default" first-keystroke="meta shift K"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl shift K"/>
        </action>

        <action id="TermLab.Sftp.FocusLocalPath"
                class="com.termlab.sftp.actions.FocusLocalSftpPathAction"
                text="Focus Local SFTP Path"
                description="Focus the local path field in the SFTP pane">
            <keyboard-shortcut keymap="$default" first-keystroke="control L"/>
            <keyboard-shortcut keymap="Mac OS X 10.5+" first-keystroke="meta L" replace-all="true"/>
            <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta L" replace-all="true"/>
        </action>

        <action id="TermLab.Sftp.FocusRemotePath"
                class="com.termlab.sftp.actions.FocusRemoteSftpPathAction"
                text="Focus Remote SFTP Path"
                description="Focus the remote path field in the SFTP pane">
            <keyboard-shortcut keymap="$default" first-keystroke="control shift L"/>
            <keyboard-shortcut keymap="Mac OS X 10.5+" first-keystroke="meta shift L" replace-all="true"/>
            <keyboard-shortcut keymap="Mac OS X" first-keystroke="meta shift L" replace-all="true"/>
        </action>
    </actions>
</idea-plugin>
