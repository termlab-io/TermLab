<idea-plugin>
    <id>com.conch.vault</id>
    <name>Credential Vault</name>
    <vendor>Conch</vendor>
    <description>Encrypted credential vault. Stores SSH credentials (passwords, keys, passphrases) on disk with AES-256-GCM and Argon2id, device-bound via IntelliJ's cross-platform PasswordSafe (Keychain / Credential Manager / libsecret / KWallet / encrypted file), and exposes them to other Conch plugins through the CredentialProvider extension point.</description>

    <!-- The credentialProvider extension point is declared by com.conch.core. -->
    <depends>com.conch.core</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!--
          LockManager is the single source of truth for "is the vault unlocked,
          and if so, what does it contain". Registered as an application service
          so every caller talks to the same instance.
        -->
        <applicationService serviceImplementation="com.conch.vault.lock.LockManager"/>

        <!-- Top-level Settings entry for the vault. parentId="root" puts it at
             the root of the Settings tree, sibling of "Conch Terminal". -->
        <applicationConfigurable
            parentId="root"
            instance="com.conch.vault.settings.ConchVaultConfigurable"
            id="conch.vault.settings"
            displayName="Credential Vault"/>

        <!-- Lock/unlock indicator widget, anchored to the right of the status bar. -->
        <statusBarWidgetFactory
            id="com.conch.vault.lockWidget"
            implementation="com.conch.vault.ui.VaultLockStatusBarWidgetFactory"
            order="last"/>
    </extensions>

    <!--
      Register the vault's credential provider under the core extension point.
      Other plugins (e.g. the forthcoming SSH plugin) query it via
      com.conch.sdk.CredentialProvider.
    -->
    <extensions defaultExtensionNs="com.conch.core">
        <credentialProvider implementation="com.conch.vault.credentials.VaultCredentialProvider"/>
        <commandPaletteContributor implementation="com.conch.vault.palette.VaultPaletteContributor"/>
    </extensions>

    <actions>
        <!-- Cmd+Shift+V (macOS) / Ctrl+Shift+V (Linux, Windows) opens the vault. -->
        <action id="com.conch.vault.OpenVault"
                class="com.conch.vault.actions.OpenVaultAction"
                text="Open Vault…"
                description="Open the Conch credential vault">
            <keyboard-shortcut keymap="$default" first-keystroke="meta shift V"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl shift V"/>
        </action>
    </actions>
</idea-plugin>
