<idea-plugin>
    <id>com.termlab.vault</id>
    <name>Credential Vault</name>
    <vendor>TermLab</vendor>
    <description>Encrypted credential vault. Stores SSH credentials (passwords, keys, passphrases) on disk with AES-256-GCM and Argon2id, device-bound via IntelliJ's cross-platform PasswordSafe (Keychain / Credential Manager / libsecret / KWallet / encrypted file), and exposes them to other TermLab plugins through the CredentialProvider extension point.</description>

    <!-- The credentialProvider extension point is declared by com.termlab.core. -->
    <depends>com.termlab.core</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!--
          LockManager is the single source of truth for "is the vault unlocked,
          and if so, what does it contain". Registered as an application service
          so every caller talks to the same instance.
        -->
        <applicationService serviceImplementation="com.termlab.vault.lock.LockManager"/>

        <!-- Top-level Settings entry for the vault. parentId="root" puts it at
             the root of the Settings tree, sibling of "TermLab Terminal". -->
        <applicationConfigurable
            parentId="root"
            instance="com.termlab.vault.settings.TermLabVaultConfigurable"
            id="termlab.vault.settings"
            displayName="Credential Vault"/>

        <!-- Lock/unlock indicator widget, anchored to the right of the status bar. -->
        <statusBarWidgetFactory
            id="com.termlab.vault.lockWidget"
            implementation="com.termlab.vault.ui.VaultLockStatusBarWidgetFactory"
            order="last"/>

        <searchEverywhereContributor
            implementation="com.termlab.vault.palette.VaultSearchEverywhereContributor$Factory"/>
    </extensions>

    <!--
      Register the vault's credential provider under the core extension point.
      Other plugins (e.g. the forthcoming SSH plugin) query it via
      com.termlab.sdk.CredentialProvider.
    -->
    <extensions defaultExtensionNs="com.termlab.core">
        <credentialProvider implementation="com.termlab.vault.credentials.VaultCredentialProvider"/>
    </extensions>

    <actions>
        <action id="com.termlab.vault.OpenVault"
                class="com.termlab.vault.actions.OpenVaultAction"
                text="Open Vault…"
                description="Open the TermLab credential vault">
            <keyboard-shortcut keymap="$default" first-keystroke="F8"/>
            <keyboard-shortcut keymap="Mac OS X 10.5+" first-keystroke="F8" replace-all="true"/>
            <keyboard-shortcut keymap="Mac OS X" first-keystroke="F8" replace-all="true"/>
        </action>

        <action id="com.termlab.vault.LockVault"
                class="com.termlab.vault.actions.LockVaultAction"
                text="Lock Vault"
                description="Seal the TermLab credential vault and drop cached credentials"/>

        <action id="com.termlab.vault.GenerateSshKey"
                class="com.termlab.vault.actions.GenerateSshKeyAction"
                text="Generate SSH Key…"
                description="Create a new Ed25519, ECDSA, or RSA key pair in the vault"/>

        <group id="com.termlab.vault.ToolsGroup" text="Credential Vault" popup="true">
            <add-to-group group-id="ToolsMenu" anchor="last"/>

            <action id="com.termlab.vault.Tools.OpenVault"
                    class="com.termlab.vault.actions.OpenVaultAction"
                    text="Open Vault…"
                    description="Open the TermLab credential vault"/>

            <action id="com.termlab.vault.Tools.ToggleLock"
                    class="com.termlab.vault.actions.LockVaultAction"
                    text="Lock Vault"
                    description="Lock or unlock the TermLab credential vault"/>
        </group>
    </actions>
</idea-plugin>
